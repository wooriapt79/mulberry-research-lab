# ============================================================
# Mulberry Research Lab — 환경 변수 템플릿
# 이 파일을 복사해서 .env.railway 로 만들고 실제 값을 입력하세요.
#
#   cp .env.example .env.railway
#   nano .env.railway   ← 실제 값 입력
# ============================================================

# ── GitHub (필수 — 이슈 댓글 · PR · 워크플로우) ─────────────
GITHUB_TOKEN=your_github_token_here

# ── Railway 인프라 (AI-SIEM Phase 2) ────────────────────────
RAILWAY_API_TOKEN=your_railway_token_here
RAILWAY_PROJECT_ID=your_project_id_here
RAILWAY_ENV_ID=your_env_id_here

# ── DeepSeek (Wayong · reason.deep) ─────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key_here

# ── Google AI (Malu · vision.* + intel.search_global) ───────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_key_here

# ── Mulberry SDK ─────────────────────────────────────────────
SDK_URL=https://mulberry-research-lab-production-7a70.up.railway.app
GATEWAY_SECRET=mulberry-agent-relay-2026

# ── 기타 ────────────────────────────────────────────────────
BANK_REPO_PATH=./data/bank
