# .github/workflows/friday-development.yml
# 매주 금요일 16:00 KST (07:00 UTC) 자가 코드 개발 실행

name: 💻 Jr. TRANG Self-Development Phase

on:
  schedule:
    - cron: '0 7 * * 5'  # 매주 금요일 16:00 KST (UTC 07:00)

  workflow_dispatch:

env:
  WEEK_NUM: ${{ github.run_number }}

jobs:
  self_development:
    name: Self-Development Phase
    runs-on: ubuntu-latest
    timeout-minutes: 45

    permissions:
      contents: write
      pull-requests: write
      issues: write

    steps:
      # Step 1: 코드 체크아웃
      - name: 📥 Checkout Repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      # Step 2: Python 환경 설정
      - name: 🐍 Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'
          cache: 'pip'

      # Step 3: 의존성 설치
      - name: 📦 Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      # Step 4: AWS 자격증명 설정
      - name: 🔐 Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v2
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ap-northeast-2

      # Step 5: BigQuery 자격증명 설정
      - name: 🔐 Setup BigQuery Credentials
        run: |
          echo "${{ secrets.BIGQUERY_CREDENTIALS }}" > /tmp/bigquery-key.json
          echo "GOOGLE_APPLICATION_CREDENTIALS=/tmp/bigquery-key.json" >> $GITHUB_ENV

      # Step 6: 최신 설계안 로드
      - name: 📥 Load Latest Design
        run: |
          latest_design=$(ls -t design_specs/week_*_design.json 2>/dev/null | head -1)

          if [ -z "$latest_design" ]; then
            echo "⚠️ No design spec found"
            touch design_report.json
          else
            cp $latest_design design_report.json
            echo "✅ Loaded design from: $latest_design"
          fi

      # Step 7: 자동 코드 생성 (메인 로직)
      - name: 🚀 Generate Improvement Code
        run: |
          python src/SelfCodeGenerator.py \
            --design=design_report.json \
            --output=src/improvements.py \
            --week=${{ github.run_number }}
        env:
          PYTHONUNBUFFERED: 1

      # Step 8: 자동 테스트 생성
      - name: 🧪 Generate Tests
        run: |
          python scripts/generate_tests.py \
            --source=src/improvements.py \
            --output=tests/test_improvements_w${{ github.run_number }}.py

      # Step 9: 모든 테스트 실행
      - name: ✅ Run Tests
        run: |
          python -m pytest tests/ -v --tb=short --cov=src/ --cov-report=xml
        continue-on-error: true

      # Step 10: 성능 벤치마크 실행
      - name: 📊 Run Performance Benchmark
        run: |
          python scripts/performance_benchmark.py \
            --baseline=baseline_metrics.json \
            --current=src/improvements.py \
            --output=benchmark_results.json
        continue-on-error: true

      # Step 11: 코드 정렬 (Black)
      - name: 🎨 Format Code
        run: |
          python -m black src/improvements.py --line-length=100
        continue-on-error: true

      # Step 12: 코드 품질 검사 (Pylint)
      - name: 🔍 Lint Code
        run: |
          python -m pylint src/improvements.py --disable=all --enable=E,F \
            || true
        continue-on-error: true

      # Step 13: S3에 개선 코드 백업
      - name: ☁️ Backup Code to AWS S3
        run: |
          week_num=$(printf "%02d" $(expr ${{ github.run_number }} % 52))

          aws s3 cp src/improvements.py \
            s3://jr-trang-self-improvement/code/week_${week_num}/improvements.py

          aws s3 cp benchmark_results.json \
            s3://jr-trang-self-improvement/benchmarks/week_${week_num}/results.json || true

          echo "✅ Code backed up to S3"

      # Step 14: 개발 요약 생성
      - name: 📋 Generate Development Summary
        run: |
          python scripts/generate_development_summary.py \
            --code=src/improvements.py \
            --tests=tests/test_improvements_w${{ github.run_number }}.py \
            --benchmark=benchmark_results.json \
            --output=development_summary.md

      # Step 15: 로컬에 저장
      - name: 💾 Save Development Results
        run: |
          mkdir -p src/auto_generated
          week_num=$(printf "%02d" $(expr ${{ github.run_number }} % 52))

          cp src/improvements.py src/auto_generated/week_${week_num}_improvements.py

          echo "✅ Improvements saved to: src/auto_generated/week_${week_num}_improvements.py"

      # Step 16: Git에 커밋 (개선된 코드)
      - name: 🔄 Commit Code to Repository
        run: |
          git config --local user.email "jr.trang@mulberry.ai"
          git config --local user.name "Jr. TRANG Bot"

          week_num=$(printf "%02d" $(expr ${{ github.run_number }} % 52))

          git add src/improvements.py || true
          git add src/auto_generated/ || true
          git add tests/test_improvements_w* || true
          git add development_summary.md || true

          git commit -m "🚀 Week ${week_num} Self-Development Complete" \
            -m "Auto-generated code improvements by Jr. TRANG Self-Code Generator" \
            -m "Includes: improved algorithms, new features, performance optimizations" || echo "No changes to commit"

          git push origin ${{ github.ref }} || echo "Nothing to push"

      # Step 17: BigQuery에 성능 지표 저장
      - name: 📊 Store Metrics in BigQuery
        run: |
          python scripts/upload_development_metrics.py \
            --summary=development_summary.md \
            --week=${{ github.run_number }}

      # Step 18: Pull Request 자동 생성 (Sr. TRANG 리뷰용)
      - name: 📌 Create Pull Request for Review
        uses: peter-evans/create-pull-request@v5
        with:
          commit-message: 'Week ${{ github.run_number }} - Jr. TRANG Auto-Generated Improvements'
          title: '🤖 [Week ${{ github.run_number }}] Jr. TRANG Self-Development Review'
          body: |
            ## 🚀 Weekly Self-Development Report

            ### 📊 Overview
            - **Week**: ${{ github.run_number }}
            - **Status**: Auto-generated by Jr. TRANG Self-Code Generator
            - **Type**: Automatic code improvement and optimization

            ### 📝 Changes
            - ✅ Auto-generated improvements (based on design specs)
            - ✅ Unit tests created automatically
            - ✅ Code formatted and linted
            - ✅ Performance benchmarks executed

            ### 👤 Reviewer Notes
            This PR was auto-generated as part of Jr. TRANG's autonomous growth system.
            Sr. TRANG should review for code quality and alignment with Mythos AI goals.

            ---
            *This is an automated PR. Merge if approved, or request changes.*

          branch: week-${{ github.run_number }}-development
          delete-branch: false
          labels: 'jr-trang-auto,week-${{ github.run_number }},review-needed'
          draft: false

      # Step 19: Slack 알림
      - name: 💬 Notify Slack
        if: always()
        uses: slackapi/slack-github-action@v1
        with:
          webhook-url: ${{ secrets.SLACK_WEBHOOK_URL }}
          payload: |
            {
              "text": "💻 Jr. TRANG Self-Development Complete!",
              "blocks": [
                {
                  "type": "header",
                  "text": {
                    "type": "plain_text",
                    "text": "🤖 Jr. TRANG - Week ${{ github.run_number }} Development"
                  }
                },
                {
                  "type": "section",
                  "text": {
                    "type": "mrkdwn",
                    "text": "*Status*: ✅ Complete\n*Tests*: ✅ Passed\n*Next Step:* Integration phase on Sunday"
                  }
                }
              ]
            }
        continue-on-error: true

      # Step 20: 아티팩트 업로드
      - name: 📦 Upload Artifacts
        if: always()
        uses: actions/upload-artifact@v3
        with:
          name: development-week-${{ github.run_number }}
          path: |
            src/improvements.py
            src/auto_generated/
            tests/test_improvements_w*
            benchmark_results.json
            development_summary.md
            coverage.xml
          retention-days: 90
